{
  "name": "nowhere-cli",
  "version": "0.2.0",
  "description": "CLI for creating, signing, encrypting, and managing Nowhere sites.",
  "private": false,
  "type": "module",
  "license": "AGPL-3.0-only",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "nowhere": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/project-maintainer/nowhere-cli.git"
  },
  "homepage": "https://github.com/project-maintainer/nowhere-cli#readme",
  "bugs": {
    "url": "https://github.com/project-maintainer/nowhere-cli/issues"
  },
  "keywords": [
    "nowhere",
    "nostr",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "cli": "tsx src/cli.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" tsup.config.ts vitest.config.ts",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\" tsup.config.ts vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm check"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "commander": "^14.0.0",
    "nostr-tools": "^2.17.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nowhere/codec": "file:../source-nowhere/nowhere/packages/codec",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.4"
  }
}
